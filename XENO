-- Atualização ao respawn
Player.CharacterAdded:Connect(function(newChar)
    Character = newChar
    task.wait(0.6)
    local hum = newChar:WaitForChild("Humanoid")
    hum.WalkSpeed = state.SpeedValue
    if state.GodMode then
        hum.MaxHealth = math.huge
        hum.Health = math.huge
    end
end)

-- Loop Ammo / Reload
task.spawn(function()
    while task.wait(0.15) do
        if state.InfAmmo or state.NoReload then
            local tool = GetCurrentWeapon()
            if tool then
                if state.InfAmmo and tool:FindFirstChild("Ammo") then
                    tool.Ammo.Value = 9999
                end
                if state.NoReload and tool:FindFirstChild("Reloading") then
                    tool.Reloading.Value = false
                end
            end
        end
    end
end)

