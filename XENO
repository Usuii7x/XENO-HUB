    titleLbl.Parent = frame
    
    local msgLbl = Instance.new("TextLabel")
    msgLbl.Size = UDim2.new(1, -10, 0, 20)
    msgLbl.Position = UDim2.new(0, 5, 0, 24)
    msgLbl.BackgroundTransparency = 1
    msgLbl.Text = msg
    msgLbl.TextColor3 = Color3.fromRGB(170, 170, 190)
    msgLbl.TextSize = 11
    msgLbl.Font = Enum.Font.Gotham
    msgLbl.TextXAlignment = Enum.TextXAlignment.Left
    msgLbl.Parent = frame
    
    frame.Position = UDim2.new(1, 0, 0, 10)
    TweenService:Create(frame, TweenInfo.new(0.4, Enum.EasingStyle.Quad), {Position = UDim2.new(1, -290, 0, 10)}):Play()
    
    task.wait(duration or 3)
    TweenService:Create(frame, TweenInfo.new(0.4, Enum.EasingStyle.Quad), {Position = UDim2.new(1, 0, 0, 10)}):Play()
    task.wait(0.4)
    frame:Destroy()
end

