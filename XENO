-- Loop de Coleta
task.spawn(function()
    while task.wait(0.4) do
        if not state.AutoCollectPerks and not state.AutoCollectPoints then continue end
        Character = Player.Character
        if not Character or not Character:FindFirstChild("HumanoidRootPart") then continue end

        for _, obj in ipairs(Workspace:GetDescendants()) do
            if obj:IsA("Part") or obj:IsA("Model") then
                local isPerk = state.AutoCollectPerks and (obj.Name:find("Perk") or obj.Name:find("Power"))
                local isPoint = state.AutoCollectPoints and (obj.Name:find("Point") or obj.Name:find("Essence") or obj.Name:find("Drop"))

                if (isPerk or isPoint) and obj:FindFirstChild("TouchInterest") then
                    local root = Character.HumanoidRootPart
                    if (root.Position - obj.Position).Magnitude < 20 then
                        firetouchinterest(root, obj, 0)
                        task.wait(0.05)
                        firetouchinterest(root, obj, 1)
                    end
                end
            end
        end
    end
end)

