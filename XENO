-- Loop do Kill Aura (melhorado)
task.spawn(function()
    while task.wait(0.08) do
        if not state.KillAura then continue end

        Character = Player.Character
        if not Character or not Character:FindFirstChild("HumanoidRootPart") then continue end

        local root = Character.HumanoidRootPart
        local closest, dist = nil, state.KillAuraRange

        for _, model in ipairs(Workspace:GetChildren()) do
            if model:IsA("Model") and model:FindFirstChild("Humanoid") and model.Humanoid.Health > 0 then
                if string.find(model.Name:lower(), "zombie") or model:FindFirstChild("Zombie") then
                    local zRoot = model:FindFirstChild("HumanoidRootPart") or model:FindFirstChild("Torso")
                    if zRoot then
                        local d = (root.Position - zRoot.Position).Magnitude
                        if d < dist then
                            dist = d
                            closest = model
                        end
                    end
                end
            end
        end

        if closest and dist <= state.KillAuraRange then
            local targetPart = state.HeadshotOnly and closest:FindFirstChild("Head") or closest:FindFirstChild("HumanoidRootPart")

            -- Knife Mode
            if state.KillAuraKnife then
                local knife = Player.Backpack:FindFirstChild("Knife") or Character:FindFirstChild("Knife")
                if knife then
                    Character.Humanoid:EquipTool(knife)
                end
            end

            -- Ataque
            local tool = GetCurrentWeapon()
            if tool then
                if state.AutoShoot and tool:FindFirstChild("RemoteEvent") then
                    tool.RemoteEvent:FireServer(targetPart.Position)
                end
            end
        end
    end
end)

